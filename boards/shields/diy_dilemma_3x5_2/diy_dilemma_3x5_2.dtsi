#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)    RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)    RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)    RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)
                                    RC(3,3) RC(3,4)    RC(3,5) RC(3,6)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";

        diode-direction = "col2row";
        row-gpios
            = <&gpio0 29 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   // Row 0 - P0.29 (R1 on PCB)
            , <&gpio0 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   // Row 1 - P0.20 (R2 on PCB)
            , <&gpio0 24 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   // Row 2 - P0.24 (R3 on PCB)
            , <&gpio1 15 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   // Row 3 - P1.15 (R4/thumb cluster)
            ;
        col-gpios
            = <&gpio1 4 GPIO_ACTIVE_HIGH>    // Col 0 - P1.04 (C2 on PCB)
            , <&gpio1 6 GPIO_ACTIVE_HIGH>    // Col 1 - P1.06 (C3 on PCB)
            , <&gpio0 11 GPIO_ACTIVE_HIGH>   // Col 2 - P0.11 (C4 on PCB)
            , <&gpio1 0 GPIO_ACTIVE_HIGH>    // Col 3 - P1.00 (C5 on PCB)
            , <&gpio0 2 GPIO_ACTIVE_HIGH>    // Col 4 - P0.02 (C6 on PCB)
            ;
    };

    // Encoders completely disabled to avoid pin conflicts
    // left_encoder: encoder_left {
    //     compatible = "alps,ec11";
    //     label = "LEFT_ENCODER";
    //     a-gpios = <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
    //     b-gpios = <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
    //     steps = <80>;
    //     status = "disabled";
    // };

    // right_encoder: encoder_right {
    //     compatible = "alps,ec11";
    //     label = "RIGHT_ENCODER";
    //     a-gpios = <&pro_micro 20 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
    //     b-gpios = <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
    //     steps = <80>;
    //     status = "disabled";
    // };

    // Sensors completely disabled - no encoders
    // sensors {
    //     compatible = "zmk,keymap-sensors";
    //     sensors = <&left_encoder &right_encoder>;
    //     triggers-per-rotation = <20>;
    // };
};